<mujoco model="shadow_hand_minimal">

  <option timestep="0.002" iterations="50" solver="PGS"/>

  <default>
    <joint damping="0.05" armature="0.001"/>
    <position kp="2.0" forcerange="-5 5"/>
    <geom condim="4" friction="1.0 0.01 0.001" rgba="0.8 0.7 0.6 1"/>
  </default>

  <worldbody>
    <light pos="0 0 2" dir="0 0 -1" diffuse="0.8 0.8 0.8"/>
    <geom name="floor" type="plane" size="1 1 0.1" rgba="0.3 0.4 0.5 1"/>

    <!-- Palm -->
    <body name="palm" pos="0 0 0.02">
      <geom type="box" size="0.04 0.03 0.01" rgba="0.8 0.7 0.6 1"/>

      <!-- Index finger -->
      <body name="index_prox" pos="0.02 0.03 0.01">
        <joint name="rh_FFJ3" type="hinge" axis="1 0 0" range="0 1.5"/>
        <geom type="capsule" size="0.007" fromto="0 0 0 0 0 0.025"/>
        <site name="index_tip" pos="0 0 0.028" size="0.008" rgba="1 0 0 1"/>

        <body name="index_dist" pos="0 0 0.025">
          <joint name="rh_FFJ2" type="hinge" axis="1 0 0" range="0 1.5"/>
          <geom type="capsule" size="0.006" fromto="0 0 0 0 0 0.02"/>
        </body>
      </body>

      <!-- Middle finger -->
      <body name="middle_prox" pos="0 0.03 0.01">
        <joint name="rh_MFJ3" type="hinge" axis="1 0 0" range="0 1.5"/>
        <geom type="capsule" size="0.007" fromto="0 0 0 0 0 0.025"/>
        <site name="middle_tip" pos="0 0 0.028" size="0.008" rgba="0 1 0 1"/>

        <body name="middle_dist" pos="0 0 0.025">
          <joint name="rh_MFJ2" type="hinge" axis="1 0 0" range="0 1.5"/>
          <geom type="capsule" size="0.006" fromto="0 0 0 0 0 0.02"/>
        </body>
      </body>

      <!-- Thumb -->
      <body name="thumb_prox" pos="-0.03 0.01 0.005" euler="0 0 -0.5">
        <joint name="rh_THJ2" type="hinge" axis="0 1 0" range="-0.7 0.7"/>
        <geom type="capsule" size="0.008" fromto="0 0 0 0 0 0.025"/>
        <site name="thumb_tip" pos="0 0 0.028" size="0.009" rgba="0 0 1 1"/>

        <body name="thumb_dist" pos="0 0 0.025">
          <joint name="rh_THJ1" type="hinge" axis="1 0 0" range="-0.3 1.5"/>
          <geom type="capsule" size="0.007" fromto="0 0 0 0 0 0.02"/>
        </body>
      </body>

      <!-- Ring finger -->
      <body name="ring_prox" pos="-0.02 0.03 0.01">
        <joint name="rh_RFJ3" type="hinge" axis="1 0 0" range="0 1.5"/>
        <geom type="capsule" size="0.007" fromto="0 0 0 0 0 0.022"/>
        <site name="ring_tip" pos="0 0 0.025" size="0.007" rgba="1 1 0 1"/>
      </body>

      <!-- Little finger -->
      <body name="little_prox" pos="-0.04 0.025 0.01">
        <joint name="rh_LFJ3" type="hinge" axis="1 0 0" range="0 1.5"/>
        <geom type="capsule" size="0.006" fromto="0 0 0 0 0 0.02"/>
        <site name="little_tip" pos="0 0 0.022" size="0.007" rgba="1 0 1 1"/>
      </body>

    </body>

    <!-- Pen object -->
    <body name="pen" pos="0 0.03 0.1">
      <joint name="pen_joint" type="free"/>
      <geom name="pen_body_1" type="cylinder" size="0.005 0.06"
            rgba="0.9 0.9 0.9 1" condim="6" friction="1.0 0.01 0.001" density="500"/>
      <site name="pen_start"  pos="0 0  0.06" size="0.004" rgba="0 1 1 1"/>
      <site name="pen_middle" pos="0 0  0"    size="0.004" rgba="0 1 1 1"/>
      <site name="pen_end"    pos="0 0 -0.06" size="0.004" rgba="0 1 1 1"/>
    </body>

  </worldbody>

  <actuator>
    <position name="act_FFJ3" joint="rh_FFJ3" ctrlrange="0 1.5"/>
    <position name="act_FFJ2" joint="rh_FFJ2" ctrlrange="0 1.5"/>
    <position name="act_MFJ3" joint="rh_MFJ3" ctrlrange="0 1.5"/>
    <position name="act_MFJ2" joint="rh_MFJ2" ctrlrange="0 1.5"/>
    <position name="act_THJ2" joint="rh_THJ2" ctrlrange="-0.7 0.7"/>
    <position name="act_THJ1" joint="rh_THJ1" ctrlrange="-0.3 1.5"/>
    <position name="act_RFJ3" joint="rh_RFJ3" ctrlrange="0 1.5"/>
    <position name="act_LFJ3" joint="rh_LFJ3" ctrlrange="0 1.5"/>
  </actuator>

  <sensor>
    <touch name="touch_thumb"  site="thumb_tip"/>
    <touch name="touch_index"  site="index_tip"/>
    <touch name="touch_middle" site="middle_tip"/>
    <touch name="touch_ring"   site="ring_tip"/>
    <touch name="touch_little" site="little_tip"/>
    <touch name="touch_pen_start"  site="pen_start"/>
    <touch name="touch_pen_middle" site="pen_middle"/>
    <touch name="touch_pen_end"    site="pen_end"/>
    <framepos  name="pen_pos"    objtype="site" objname="pen_middle"/>
    <framequat name="pen_orient" objtype="site" objname="pen_middle"/>
  </sensor>

</mujoco>